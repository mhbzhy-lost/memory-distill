  },
  {
    "captured_at": "2026-05-21T09:50:51.121768Z",
    "final_url": "https://nextjs.org/docs/messages/invalid-dynamic-suspense",
    "quote_hash": "sha256:12c1528f567d5c018a684cfa50fbec162e1c5e1db8f71f67c72d4775fcb56427",
    "section_anchor": "root",
    "short_excerpt": "Next.js will use React.lazy when suspense is set to true, when your dynamic-imported component is loading, React will use the closest suspense boundary's fallback.",
    "source_id": "next-invalid-dynamic-suspense",
    "source_type": "official_error_doc",
    "span_id": "next-invalid-dynamic-suspense-18",
    "text": "Next.js will use React.lazy when suspense is set to true, when your dynamic-imported component is loading, React will use the closest suspense boundary's fallback.",
    "url": "https://nextjs.org/docs/messages/invalid-dynamic-suspense"
  },
  {
    "captured_at": "2026-05-21T09:50:51.121768Z",
