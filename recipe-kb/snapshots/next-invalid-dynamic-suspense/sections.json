  {
    "captured_at": "2026-05-21T09:50:51.121768Z",
    "final_url": "https://nextjs.org/docs/messages/invalid-dynamic-suspense",
    "quote_hash": "sha256:1f56bae4302a5d957013a90da4ab3067673f5d0f61f5a761b8908dc8100398aa",
    "section_anchor": "root",
    "short_excerpt": "Next.js will use React.lazy when suspense is set to true. React 18 or newer will always try to resolve the Suspense boundary on the server. This behavior can not be disabled, thus the ssr: false is ignored with suspense: true .",
    "source_id": "next-invalid-dynamic-suspense",
    "source_type": "official_error_doc",
    "span_id": "next-invalid-dynamic-suspense-13",
    "text": "Next.js will use React.lazy when suspense is set to true. React 18 or newer will always try to resolve the Suspense boundary on the server. This behavior can not be disabled, thus the ssr: false is ignored with suspense: true .",
    "url": "https://nextjs.org/docs/messages/invalid-dynamic-suspense"
  },
  {
    "captured_at": "2026-05-21T09:50:51.121768Z",
    "final_url": "https://nextjs.org/docs/messages/invalid-dynamic-suspense",
    "quote_hash": "sha256:abaa78d51058c2b46c8055c10ba2678a633b2d7777599621dc00626254480c16",
    "section_anchor": "root",
    "short_excerpt": "You should write code that works in both client-side and server-side.",
    "source_id": "next-invalid-dynamic-suspense",
    "source_type": "official_error_doc",
    "span_id": "next-invalid-dynamic-suspense-14",
    "text": "You should write code that works in both client-side and server-side.",
    "url": "https://nextjs.org/docs/messages/invalid-dynamic-suspense"
  },
