  },
  {
    "captured_at": "2026-05-26T08:42:53.083772Z",
    "final_url": "https://fastapi.tiangolo.com/tutorial/middleware/",
    "quote_hash": "sha256:e5d9ef0069c94a2ac8e1e81dfb79b4f901ecc2088d55e49b9819c02aeebb2a88",
    "section_anchor": "root",
    "short_excerpt": "Here we use time.perf_counter() instead of time.time() because it can be more precise for these use cases. \ud83e\udd13",
    "source_id": "fastapi-middleware",
    "source_type": "official_doc",
    "span_id": "fastapi-middleware-32",
    "text": "Here we use time.perf_counter() instead of time.time() because it can be more precise for these use cases. \ud83e\udd13",
    "url": "https://fastapi.tiangolo.com/tutorial/middleware/"
  },
  {
    "captured_at": "2026-05-26T08:42:53.083772Z",
    "final_url": "https://fastapi.tiangolo.com/tutorial/middleware/",
    "quote_hash": "sha256:7a7cd448ba2c2ac8c3cd39e7208a97d5302924c04f8d5b1e99754b68d0b21a53",
