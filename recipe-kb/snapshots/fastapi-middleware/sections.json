    "section_anchor": "root",
    "short_excerpt": "You can then further modify the response before returning it.",
    "source_id": "fastapi-middleware",
    "source_type": "official_doc",
    "span_id": "fastapi-middleware-20",
    "text": "You can then further modify the response before returning it.",
    "url": "https://fastapi.tiangolo.com/tutorial/middleware/"
  },
  {
    "captured_at": "2026-05-26T08:42:53.083772Z",
    "final_url": "https://fastapi.tiangolo.com/tutorial/middleware/",
    "quote_hash": "sha256:d72a4f82b40c3dbadd1f7535a98499a0da3d61bbc2ec6141eb7125ee6fad3fa8",
    "section_anchor": "root",
    "short_excerpt": "import time from fastapi import FastAPI , Request app = FastAPI () @app . middleware ( \"http\" ) async def add_process_time_header ( request : Request , call_next ): start_time = time . perf_counter () response = await call_next ( request ) process_time = time . perf_counter () - start_time response . headers [ \"X-Process-Time\" ] = str ( process_time ) return response",
    "source_id": "fastapi-middleware",
    "source_type": "official_doc",
    "span_id": "fastapi-middleware-21",
    "text": "import time from fastapi import FastAPI , Request app = FastAPI () @app . middleware ( \"http\" ) async def add_process_time_header ( request : Request , call_next ): start_time = time . perf_counter () response = await call_next ( request ) process_time = time . perf_counter () - start_time response . headers [ \"X-Process-Time\" ] = str ( process_time ) return response",
    "url": "https://fastapi.tiangolo.com/tutorial/middleware/"
  },
